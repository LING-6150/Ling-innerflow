# ── Stage 1: Build Vue 3 frontend ─────────────────────────────────
FROM node:20-alpine AS frontend-builder
WORKDIR /app

COPY frontend/package*.json ./
RUN npm ci

COPY frontend/ .
RUN npm run build

# ── Stage 2: Nginx ─────────────────────────────────────────────────
FROM nginx:alpine
COPY --from=frontend-builder /app/dist /usr/share/nginx/html
COPY nginx.ecs.conf /etc/nginx/conf.d/default.conf

EXPOSE 80
